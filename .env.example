# Real multi-agent runtime: local | assisted | agents
# Set to local if you want deterministic smoke tests without an API key.
AGENT_TEAM_RUNTIME=agents

# Required for AGENT_TEAM_RUNTIME=agents and for AGENT_TEAM_LIVE=1.
OPENAI_API_KEY=

# Shared fallback model when per-role overrides are not set.
AGENT_TEAM_MODEL=gpt-5.4

# Optional per-role model overrides for the Agents SDK runtime.
AGENT_TEAM_MANAGER_MODEL=gpt-5.4
AGENT_TEAM_PLANNER_MODEL=gpt-5.4
AGENT_TEAM_IMPLEMENTER_MODEL=gpt-5-codex
AGENT_TEAM_REVIEWER_MODEL=gpt-5.4
AGENT_TEAM_TESTER_MODEL=gpt-5-mini

# Assisted mode keeps the local heuristics but adds Responses API narration.
AGENT_TEAM_LIVE=0

AGENT_TEAM_TRANSPORT=stdio
AGENT_TEAM_HTTP_HOST=127.0.0.1
AGENT_TEAM_HTTP_PORT=3000
AGENT_TEAM_HTTP_PATH=/mcp
